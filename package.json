{
  "name": "whyshu-vwe",
  "version": "1.0.0",
  "private": true,
  "description": "Visual Website Editor - 可视化拖拽式网站编辑器",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @vwe/editor dev",
    "dev:renderer": "pnpm --filter @vwe/renderer dev",
    "build": "pnpm --filter @vwe/components build && pnpm --filter @vwe/renderer build && pnpm --filter @vwe/editor build",
    "build:editor": "pnpm --filter @vwe/editor build",
    "build:renderer": "pnpm --filter @vwe/renderer build",
    "build:components": "pnpm --filter @vwe/components build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
